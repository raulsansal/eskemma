rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ========== SEFIX DASHBOARD DATA (LECTURA PÚBLICA) ==========
    match /sefix/{allPaths=**} {
      // ✅ Lectura pública para dashboard de Shiny Apps
      allow read: if true;

      // ✅ Escritura solo para admins autenticados
      allow write: if request.auth != null &&
                     (request.auth.token.role == "admin" ||
                      request.auth.token.admin == true);
    }

    // ========== AVATARES DE USUARIOS ==========
    match /avatars/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ========== IMÁGENES DE POSTS (BLOG) ==========
    match /post-images/{postId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

    match /post-images/{postId}/secondary/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == "admin";
    }

  }
}
